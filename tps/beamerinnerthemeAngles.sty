

\mode<presentation>

%
% Set some marking boxes adjusted for this theme

\newcommand\sandiabeamer@makeUCNIbonusBox[1]{%
  \node (ucni-bonus-box)
  [inner sep=1mm,rectangle,align=left,text width=33mm,font=\TINY,
  above=0.5mm of cui-extra-box.north, anchor=south, text opacity=1]
  {\sffamily #1 };
}

\newcommand\sandiabeamer@makeCUIextraBox[1]{%
  \node (cui-extra-box)
  [inner sep=1mm,rectangle,align=left,text width=33mm,font=\TINY,
  above=0mm of tbird-logo.south west,anchor=south , text opacity=1]
  {\sffamily #1 };
}

\newcommand\sandiabeamer@UCNIbox{%
  {\bfseries \sffamily UNCLASSIFIED CONTROLLED NUCLEAR INFORMATION \newline NOT FOR PUBLIC DISSEMINATION}\\
  \vspace*{0.5mm}
    {\sffamily Unauthorized dissemination subject to civil and criminal sanctions under Section 148 of the Atomic Energy Act of 1954, as amended (42 U.S.C. 2168).}
}


