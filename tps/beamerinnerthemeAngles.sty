	  	  [font=\TINY\sffamily,align=left, text width = 70mm,
	  	  above = 2.0mm of DOElogo.north, anchor=south east]
	  	  {Controlled By: \SAND@mark@CUIcontrolled};}{}
  
	  \node (text-anchor)
         [anchor=south east]
         at \offcorner{north west}{12.96mm,-5mm}   
		 {};

	  \iftoggle{SAND@CUIorCLASS}{        
        \ifcsvoid{sandiabeamer@CUI@whichBox}{}{\sffamily\sandiabeamer@UCI@whichBox}
        \ifcsvoid{sandiabeamer@CUI@whichExtraBox}{}{\sffamily\sandiabeamer@CUI@whichExtraBox}
        \ifcsvoid{sandiabeamer@CUI@whichBonusBox}{}{\sffamily\sandiabeamer@CUI@whichBonusBox}
          
        \node (CUImarktop) [rectangle,align=center,text=white,font=\Tiny\sffamily,above=1.5mm of text-anchor.south east,anchor=south west]
        	{ \SAND@mark@headfoot };
        	
        \node (CUImarkbottom) [rectangle,align=center,text=white,font=\Tiny\sffamily,anchor=south west]
        	at \offcorner{south west}{12.96mm,3.5mm}
        	{ \SAND@mark@headfoot };

      }{
		\iftoggle{SAND@UUR}{
        \node (CUImarktop) [rectangle,align=center,family=\sffamily,text=white,font=\Tiny,above=1.5mm of text-anchor.south east,anchor=south west]
        	{ \SAND@UURmark };
        \node (CUImarkbottom) [rectangle,align=center,text=white,family=\sffamily,font=\Tiny,anchor=south west]
        	at \offcorner{south west}{12.96mm,3.5mm}
        	{ \SAND@UURmark };
        }{}
      }

	  \node (SNLlogo)
	  	[anchor=north west]
	  	at (text-anchor)
	  	{\includegraphics[height=8mm]{assets/snl-white.png}};
	  
	  \node (service)
	  	[text=white,font=\footnotesize,align=left, below=2mm of SNLlogo.south west,anchor=north west]
	  	{\sffamily Exceptional service in the national interest};
      %
      % these *should* all be in the same place for all 16:9 versions
      \node (title-text) 
      	[text width=95mm, text=white,below=5mm of service.south west, font=\Large,align=left,anchor=north west] at (service.south west)
   		{\sffamily \inserttitle };

       \node (subtitle-text) 
       	 [text width=92mm, rectangle,text=white,font=\footnotesize,align=left,below=8mm of title-text.south west, anchor=south west]
      	 { \sffamily \insertsubtitle };

      \node (author-text) 
      	[text width=82mm, rectangle,text=snllightblue,font=\small,below=8mm of subtitle-text.south west, anchor=north west] 
      	at (subtitle-text.south west)
      	{ \sffamily \insertauthor };
      	
      \ifsandiabeamer@UX@titledate
      \node (date) 
      	[rectangle,text width=40mm, font=\tiny, text=white, below=5mm of author-text.south west,anchor=north west]
      	{ \sffamily\insertdate };
      \fi
      
    \end{scope}
  
  \end{tikzpicture}
  \tikzexternalenable

}


