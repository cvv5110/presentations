	  \filldraw[color=snllightblue] \offcorner{south west}{12.96mm,18.24mm} -- \offcorner{south east}{0mm,18.24mm} -- \offcorner{south east}{0mm,8.4mm} -- \offcorner{south west}{22.69mm,8.4mm};

	  % \fontsize{2}{3}\selectfont
      \node (thanks)
