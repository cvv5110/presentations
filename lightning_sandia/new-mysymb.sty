\newcommand\insertfig[3]{
\begin{figure}
\centering
\includegraphics[width=#2\textwidth]{#1}
\vspace{10pt}
\caption{#3}\label{#1}
\end{figure}
}
\newcommand\insertfighere[3]{
\begin{figure}[h!]
\centering
\includegraphics[width=#2\textwidth]{#1}
\vspace{10pt}
\caption{#3}\label{#1}
\end{figure}
}
\newcommand\insertfigr[3]{
\begin{minipage}{#2\linewidth}
\begin{figure}[H]
\centering
\includegraphics[width=\textwidth]{#1}
\vspace{10pt}
\caption{#3}\label{#1}
\end{figure}
\end{minipage}
}

\newcommand\insertfigs[3]{
\subfigure[\label{#1}#3]{\includegraphics[width=#2\linewidth]{#1}}
}
